{
  "buildCommand": "node_modules/.bin/tsc --build --force && cd artifacts/pharmacie-alger && pnpm build",
  "outputDirectory": "artifacts/pharmacie-alger/dist/public",
  "installCommand": "corepack enable && pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lightslategray-dinosaur-220659.hostingersite.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
